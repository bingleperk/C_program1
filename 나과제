
#include <stdio.h>

int main()
{
    char line1[81], line2[81];

    gets(line1);
    gets(line2);

    int i=0;
    while(line1[i] != '\0')
    {
        i++;
    }
    line1[i] = ' ';
    i++;
    int j=0;
    
    while (line2[j] != '\0')
    {
        line1[i] = line2[j];
        i++;
        j++;
    }
    
    line1[i] = '\0';
    
    
    
    printf("%s",line1);

    return 0;
}
