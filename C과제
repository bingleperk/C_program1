void err(float *error,float A[ROW_NUM][COL_NUM], float C[ROW_NUM][COL_NUM])
{
    float diff=0;
    float diff_n=0;
    float D;
    for(int i=0; i<ROW_NUM; i++)
    {
        for(int j=0; j<COL_NUM; j++)
        { 
            D=A[i][j] - C[i][j];
            diff = (D>diff) ? D : diff;
            
            diff_n = (D<diff_n) ? D : diff_n;
        }
    }
    
    *error = (diff > -diff_n) ? diff : -diff_n;
    
}




void q_C(char B[ROW_NUM][COL_NUM],float C[ROW_NUM][COL_NUM], float scale)
{
    for(int i=0; i<ROW_NUM; i++)
    {
        for(int j=0; j<COL_NUM; j++)
        {
            C[i][j] = B[i][j] * scale;
        }
    }
}








void q_B(float A[ROW_NUM][COL_NUM], char B[ROW_NUM][COL_NUM], float *scale) //배열 B에 양자화 값 각각 넣어주기
{
    int Q;//양자화 값
    for(int i=0; i<ROW_NUM; i++)
    {
        for(int j=0; j<COL_NUM; j++)
        {
            //B[i][j] = round(A[i][j] / *scale);

            if (A[i][j]<0)
            {
                Q = (A[i][j] / *scale) - 0.5;
                B[i][j] = Q;
            }
            else
            {
                Q = (A[i][j] / *scale) + 0.5;
                B[i][j] = Q;
            }
        }
    }
}











void get_scale(float *scale, float *max, float *min)
{

    float s_max;
    if (*min<0)
    {
        if (-*min<*max)
        {
            s_max = *max;
        }

        else
        {
            s_max = - *min;
        }
    }
    else //min>0--> min은 양수니까 무조건 max값의 절댓값이 더 큼
    {
            s_max = *max;
    }

    *scale = s_max/127; //scale얻음
    
} 



void minmax (float A[ROW_NUM][COL_NUM], float *min, float *max) //최소 최대 뜯어오기.
{
        int i, j;
        for (i=0; i<ROW_NUM; i++)
        {
            for(j=0; j<COL_NUM; j++)
            {
                *min=(*min>A[i][j]) ? A [i][j] : *min;
                *max=(*max<A[i][j]) ? A [i][j] : *max;
            }
        }

}
